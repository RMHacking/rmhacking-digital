# ────────────────────────────────────────────────────────────────
# RMHacking — Investigação Digital
# Configurações de Ambiente
#
# INSTRUÇÕES:
#   1. Renomeie este arquivo para ".env"
#   2. Preencha os valores abaixo
#   3. NUNCA envie o arquivo .env para o Git
# ────────────────────────────────────────────────────────────────

# ── Senha de Acesso (OBRIGATÓRIO alterar antes do deploy!) ──────
# Esta é a senha única que protege todo o sistema
ACCESS_PASSWORD=SUA_SENHA_AQUI_MINIMO_8_CARACTERES

# ── Segredo da sessão (gere uma string aleatória longa) ─────────
SESSION_SECRET=gere-uma-string-longa-e-aleatoria-aqui-123xyzABC

# ── Porta do servidor (padrão: 3000) ────────────────────────────
PORT=3000

# ── Caminho do banco de dados SQLite ────────────────────────────
# No Railway/Render, use um caminho no volume persistente
DB_PATH=rmhacking.db
